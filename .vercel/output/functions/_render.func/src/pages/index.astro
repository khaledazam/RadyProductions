---
import Layout from '../layouts/Layout.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro'; // Scene 1 & 2
import About from '../components/About.astro'; // Scene 3
import Services from '../components/Services.astro'; // Scene 4
import Portfolio from '../components/Portfolio.astro'; // Scene 5
import CinematicExperience from '../components/CinematicExperience.astro'; // Scene 6
import SceneCreative from '../components/SceneCreative.astro'; // Scene 7
import InfiniteFilmStrip from '../components/InfiniteFilmStrip.astro'; // Scene 8
import Testimonials from '../components/Testimonials.astro'; // Scene 9
import SceneEmotion from '../components/SceneEmotion.astro'; // Scene 10
import Footer from '../components/Footer.astro';
---

<Layout title="RADY Video Production | Cinematic Storytelling">
  
  <!-- Cinematic Intro with Audio Logic -->
  <LoadingScreen />
  
  <Navbar />
  
  <!-- Continuous GSAP Timeline Container -->
  <main id="cinematic-scroll-container" class="relative overflow-hidden w-full bg-brand-matte">
    
    <!-- Scene 1 & 2: The Camera Lens & Wedding Moment -->
    <Hero />
    
    <!-- Scene 3: About (Philosophy & Legacy) -->
    <About />
    
    <!-- Scene 4: Services (Cinematic Offerings) -->
    <Services />

    <!-- Scene 5: Portfolio (Selected Works) -->
    <Portfolio />
    
    <!-- Scene 6: Cinematic Experience (Interactive 3D Aperture & Helix) -->
    <CinematicExperience />
    
    <!-- Scene 7: The Creative Process -->
    <SceneCreative />
    
    <!-- Scene 8: The Final Cinematic Result (Infinite Film Strip) -->
    <InfiniteFilmStrip />
    
    <!-- Scene 9: Testimonials (Client Stories) -->
    <Testimonials />
    
    <!-- Scene 10: Client Emotion -->
    <SceneEmotion />

  </main>
  
  <Footer />

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Global scene transition logic will be dispatched here or managed within individual scenes
  // The HUD values are updated dynamically when scenes enter the viewport.
</script>
