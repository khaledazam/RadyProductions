---
import { Phone } from '@lucide/astro';
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 py-6 border-b border-transparent">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center">
    
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group select-none">
      <div class="relative w-10 h-10 flex items-center justify-center border border-brand-gold/30 rounded-full group-hover:border-brand-gold duration-500 overflow-hidden">
        <div class="absolute inset-0 bg-brand-gold/5 scale-0 group-hover:scale-100 transition-transform duration-500 rounded-full"></div>
        <span class="font-serif text-xl text-brand-gold font-bold relative z-10">R</span>
      </div>
      <div class="flex flex-col">
        <span class="font-serif text-lg md:text-xl font-bold tracking-wider text-gold-gradient">Rady</span>
        <span class="text-[8px] tracking-[0.3em] uppercase text-brand-champagne/80 -mt-1">Video Production</span>
      </div>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden lg:flex items-center gap-8">
      {['About', 'Services', 'Portfolio', 'Experience', 'Testimonials'].map((item) => (
        <a 
          href={`#${item.toLowerCase()}`} 
          class="magnetic-link text-xs tracking-[0.2em] uppercase text-brand-ivory/70 hover:text-brand-gold transition-colors duration-300 py-2 relative group"
        >
          {item}
          <span class="absolute bottom-0 left-1/2 w-0 h-[1px] bg-brand-gold transition-all duration-300 group-hover:w-full group-hover:left-0"></span>
        </a>
      ))}
    </nav>

    <!-- CTAs (Desktop) -->
    <div class="hidden lg:flex items-center gap-6">
      <a 
        href="tel:+201066151490" 
        class="flex items-center gap-2 text-xs tracking-wider text-brand-ivory/80 hover:text-brand-gold transition-colors duration-300"
      >
        <Phone class="w-3.5 h-3.5 text-brand-gold" />
        <span>+20 106 615 1490</span>
      </a>
      <a 
        href="#contact" 
        class="magnetic-btn px-6 py-2.5 bg-transparent border border-brand-gold text-brand-gold hover:text-brand-matte text-xs tracking-[0.15em] uppercase transition-all duration-500 relative overflow-hidden font-medium group"
      >
        <span class="absolute inset-0 bg-gold-gradient translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out z-0"></span>
        <span class="relative z-10">Book Now</span>
      </a>
    </div>

    <!-- Mobile Hamburger Toggle -->
    <button 
      id="mobile-menu-toggle" 
      class="lg:hidden w-10 h-10 flex flex-col justify-center items-center gap-1.5 relative z-50 text-brand-ivory hover:text-brand-gold transition-colors duration-300 focus:outline-none"
      aria-label="Toggle Navigation Menu"
    >
      <span class="w-6 h-[1.5px] bg-current transition-transform duration-300 origin-center" id="hamburger-top"></span>
      <span class="w-6 h-[1.5px] bg-current transition-all duration-300" id="hamburger-middle"></span>
      <span class="w-6 h-[1.5px] bg-current transition-transform duration-300 origin-center" id="hamburger-bottom"></span>
    </button>

  </div>
</header>

<!-- Mobile Navigation Menu Overlay -->
<div 
  id="mobile-menu" 
  class="fixed inset-0 bg-brand-matte/95 backdrop-blur-xl z-45 translate-x-full transition-transform duration-500 lg:hidden flex flex-col justify-between p-8 pt-32"
>
  <nav class="flex flex-col gap-6 items-center">
    {['About', 'Services', 'Portfolio', 'Experience', 'Testimonials'].map((item) => (
      <a 
        href={`#${item.toLowerCase()}`} 
        class="mobile-nav-link font-serif text-3xl text-brand-ivory/80 hover:text-brand-gold transition-colors duration-300 py-2"
      >
        {item}
      </a>
    ))}
  </nav>
  
  <div class="flex flex-col items-center gap-6 border-t border-brand-charcoal pt-8">
    <a 
      href="tel:+201066151490" 
      class="flex items-center gap-3 text-sm tracking-wider text-brand-ivory/85 hover:text-brand-gold"
    >
      <Phone class="w-4 h-4 text-brand-gold" />
      <span>+20 106 615 1490</span>
    </a>
    <a 
      href="#contact" 
      class="w-full text-center py-4 bg-transparent border border-brand-gold text-brand-gold text-sm tracking-[0.2em] uppercase hover:bg-brand-gold hover:text-brand-matte transition-all duration-500"
    >
      Book Now
    </a>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  // --- Scroll Sticky Behavior ---
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('glassmorphism', 'py-4');
      navbar?.classList.remove('py-6', 'border-transparent');
      navbar?.classList.add('border-b', 'border-brand-charcoal/20');
    } else {
      navbar?.classList.remove('glassmorphism', 'py-4', 'border-b', 'border-brand-charcoal/20');
      navbar?.classList.add('py-6', 'border-transparent');
    }
  });

  // --- Magnetic Buttons Effect ---
  const magneticButtons = document.querySelectorAll('.magnetic-btn');
  magneticButtons.forEach((btn) => {
    btn.addEventListener('mousemove', (e: any) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      
      gsap.to(btn, {
        x: x * 0.4,
        y: y * 0.4,
        duration: 0.3,
        ease: 'power2.out'
      });
    });

    btn.addEventListener('mouseleave', () => {
      gsap.to(btn, {
        x: 0,
        y: 0,
        duration: 0.5,
        ease: 'elastic.out(1.1, 0.4)'
      });
    });
  });

  // --- Magnetic Link Effect (Lighter Pull) ---
  const magneticLinks = document.querySelectorAll('.magnetic-link');
  magneticLinks.forEach((link) => {
    link.addEventListener('mousemove', (e: any) => {
      const rect = link.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      
      gsap.to(link, {
        x: x * 0.25,
        y: y * 0.15,
        duration: 0.3,
        ease: 'power2.out'
      });
    });

    link.addEventListener('mouseleave', () => {
      gsap.to(link, {
        x: 0,
        y: 0,
        duration: 0.5,
        ease: 'power2.out'
      });
    });
  });

  // --- Mobile Menu Toggle ---
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hTop = document.getElementById('hamburger-top');
  const hMiddle = document.getElementById('hamburger-middle');
  const hBottom = document.getElementById('hamburger-bottom');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  let isMenuOpen = false;

  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      // Open Menu
      mobileMenu?.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden';
      // hamburger animation
      gsap.to(hTop, { rotate: 45, y: 7.5, duration: 0.3 });
      gsap.to(hMiddle, { opacity: 0, scale: 0, duration: 0.2 });
      gsap.to(hBottom, { rotate: -45, y: -7.5, duration: 0.3 });
      
      // Links stagger fade in
      gsap.fromTo('.mobile-nav-link', 
        { opacity: 0, y: 30 }, 
        { opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: 'power2.out', delay: 0.2 }
      );
    } else {
      // Close Menu
      mobileMenu?.classList.add('translate-x-full');
      document.body.style.overflow = '';
      // hamburger reset
      gsap.to(hTop, { rotate: 0, y: 0, duration: 0.3 });
      gsap.to(hMiddle, { opacity: 1, scale: 1, duration: 0.3 });
      gsap.to(hBottom, { rotate: 0, y: 0, duration: 0.3 });
    }
  };

  toggleBtn?.addEventListener('click', toggleMenu);

  // Close menu when link is clicked
  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  // Handle outside click to close menu
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (isMenuOpen && mobileMenu && !mobileMenu.contains(target) && !toggleBtn?.contains(target)) {
      toggleMenu();
    }
  });
</script>
