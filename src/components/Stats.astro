---
const stats = [
  { target: 250, suffix: "+", label: "Projects Completed" },
  { target: 180, suffix: "+", label: "Happy Clients" },
  { target: 120, suffix: "+", label: "Weddings Covered" },
  { target: 45, suffix: "+", label: "Commercial Campaigns" }
];
---

<section id="stats" class="relative py-24 bg-brand-charcoal/20 overflow-hidden font-sans border-t border-brand-charcoal/20">
  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 md:gap-8 justify-items-center">
      {stats.map((s) => (
        <div class="flex flex-col items-center text-center select-none stat-item">
          <!-- Animated Counter Numbers -->
          <div class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-gold-gradient flex items-baseline">
            <span class="stat-number" data-target={s.target}>0</span>
            <span>{s.suffix}</span>
          </div>
          <!-- Label -->
          <p class="text-[10px] md:text-xs tracking-[0.25em] uppercase text-brand-ivory/60 mt-3 font-medium">
            {s.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // --- Entry Reveal ---
  gsap.fromTo('.stat-item', 
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#stats',
        start: 'top 85%'
      }
    }
  );

  // --- Counter Count Up Animation ---
  const countElements = document.querySelectorAll('.stat-number');
  countElements.forEach((el) => {
    const target = parseInt(el.getAttribute('data-target') || '0');
    const countObj = { value: 0 };

    gsap.to(countObj, {
      value: target,
      duration: 2.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 90%',
        toggleActions: 'play none none none'
      },
      onUpdate: () => {
        el.textContent = Math.floor(countObj.value).toString();
      }
    });
  });
</script>
