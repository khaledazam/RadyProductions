---
---
<section id="about" class="relative min-h-screen py-32 bg-brand-matte overflow-hidden flex items-center justify-center font-sans">
  <!-- Decorative background line -->
  <div class="absolute right-0 top-0 w-[1px] h-full bg-gradient-to-b from-transparent via-brand-gold/10 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center">
    
    <!-- Image Column (Left: cols 1-6) -->
    <div class="lg:col-span-6 relative group" id="about-image-wrapper">
      
      <!-- Luxury Gold Corner Borders -->
      <div class="absolute -top-4 -left-4 w-12 h-12 border-t-2 border-l-2 border-brand-gold z-10 pointer-events-none"></div>
      <div class="absolute -bottom-4 -right-4 w-12 h-12 border-b-2 border-r-2 border-brand-gold z-10 pointer-events-none"></div>

      <!-- Image container with mask -->
      <div class="relative overflow-hidden w-full h-[350px] md:h-[500px] bg-brand-charcoal/50 border border-brand-charcoal">
        <!-- Overlay -->
        <div class="absolute inset-0 bg-brand-matte/20 z-10 transition-colors duration-500 group-hover:bg-transparent"></div>
        <img 
          src="/assets/about_camera.png" 
          alt="Premium Cinematic Camera Setup" 
          class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-1000 ease-out"
          loading="lazy"
        />
      </div>

      <!-- Tiny statistics highlight -->
      <div class="absolute bottom-6 left-6 glassmorphism p-4 md:p-6 z-20 max-w-[200px] border-l-2 border-brand-gold">
        <h4 class="font-serif text-3xl font-bold text-brand-gold">4K HDR</h4>
        <p class="text-[9px] uppercase tracking-[0.2em] text-brand-champagne/80 mt-1" data-i18n="about.badge">Cinematographic Standards</p>
      </div>
    </div>

    <!-- Copy Column (Right: cols 7-12) -->
    <div class="lg:col-span-6 flex flex-col justify-center">
      <span class="text-xs tracking-[0.4em] uppercase text-brand-gold font-semibold mb-6 block" id="about-subtitle" data-i18n="about.tag">
        Our Philosophy
      </span>
      
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-brand-ivory leading-tight mb-8" id="about-title">
        <span data-i18n="about.title">Crafting Timeless Timelines.</span> <br />
        <span class="text-gold-gradient" data-i18n="about.title_gold">Visualizing Legacies.</span>
      </h2>

      <!-- GSAP Animated Text Block -->
      <div class="flex flex-col gap-6 text-brand-ivory/70 text-sm md:text-base leading-relaxed tracking-wide">
        <p class="about-reveal-para" data-i18n="about.p1">
          Every project we undertake is a blank canvas. We search for the organic emotion, the unspoken bond, the silent roar of a brand. With <strong class="text-brand-gold font-normal">RADY Video Production</strong>, your vision transitions from a simple concept into a breathtaking visual symphony.
        </p>
        <p class="about-reveal-para" data-i18n="about.p2">
          Founded in Cairo, we offer high-end film production services across Egypt and globally. Combining cutting-edge camera rigs, precision drone work, and elite color grading, we create masterpieces that don't just occupy screens—they live in memory.
        </p>
        <p class="about-reveal-para" data-i18n="about.p3">
          We don't just capture motion; we build cinematic gravity. Because some moments deserve more than standard recording. They deserve to be unforgettable.
        </p>
      </div>

      <!-- Signature Mark -->
      <div class="mt-12 flex items-center gap-4 opacity-80" id="about-signature">
        <div class="w-12 h-[1px] bg-brand-gold/50"></div>
        <span class="font-serif italic text-lg text-brand-champagne" data-i18n="about.signature">Rady &amp; Team</span>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // --- HUD Updates ---
  ScrollTrigger.create({
    trigger: '#about',
    start: 'top center',
    end: 'bottom center',
    onEnter: () => {
      window.dispatchEvent(new CustomEvent('hudUpdate', {
        detail: { iso: '200', shutter: '1/60', fps: '24', aperture: '4.0', wb: '5200K' }
      }));
    },
    onEnterBack: () => {
      window.dispatchEvent(new CustomEvent('hudUpdate', {
        detail: { iso: '200', shutter: '1/60', fps: '24', aperture: '4.0', wb: '5200K' }
      }));
    }
  });

  // --- ScrollTrigger Animations ---
  // Left Column Image reveal
  gsap.fromTo('#about-image-wrapper', 
    { opacity: 0, x: -50 },
    {
      opacity: 1,
      x: 0,
      duration: 1.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#about-image-wrapper',
        start: 'top 80%',
        toggleActions: 'play none none none'
      }
    }
  );

  // Subtitle and Title reveal
  gsap.fromTo('#about-subtitle',
    { opacity: 0, y: 20 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#about-subtitle',
        start: 'top 85%'
      }
    }
  );

  gsap.fromTo('#about-title',
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#about-title',
        start: 'top 85%'
      }
    }
  );

  // Story paragraphs reveal
  const paras = document.querySelectorAll('.about-reveal-para');
  paras.forEach((para) => {
    gsap.fromTo(para,
      { opacity: 0, y: 25 },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: para,
          start: 'top 85%'
        }
      }
    );
  });

  // Signature line reveal
  gsap.fromTo('#about-signature',
    { opacity: 0, scaleX: 0, originX: 0 },
    {
      opacity: 0.8,
      scaleX: 1,
      duration: 1.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#about-signature',
        start: 'top 90%'
      }
    }
  );
</script>
