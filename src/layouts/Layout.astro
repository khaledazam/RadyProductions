      // Language switcher logic
      const i18n = {
        current: (localStorage.getItem('radyLang') || 'en') as 'en' | 'ar',

        apply(lang: 'en' | 'ar') {
          this.current = lang;
          localStorage.setItem('radyLang', lang);

          const html = document.documentElement;
          html.lang = lang;
          html.dir = lang === 'ar' ? 'rtl' : 'ltr';

          // Update all elements with data-i18n
          document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n')!;
            const text = translations[lang]?.[key];
            if (text !== undefined) el.textContent = text;
          });

          // Update toggle button visuals — desktop AND mobile
          const enLabel  = document.getElementById('lang-en');
          const arLabel  = document.getElementById('lang-ar');
          const enLabelM = document.getElementById('lang-en-m');
          const arLabelM = document.getElementById('lang-ar-m');
          const goldColor = 'var(--color-brand-gold)';
          const dimColor  = 'rgba(245,245,245,0.4)';
          if (enLabel)  enLabel.style.color  = lang === 'en' ? goldColor : dimColor;
          if (arLabel)  arLabel.style.color  = lang === 'ar' ? goldColor : dimColor;
          if (enLabelM) enLabelM.style.color = lang === 'en' ? goldColor : dimColor;
          if (arLabelM) arLabelM.style.color = lang === 'ar' ? goldColor : dimColor;

          // Refresh ScrollTrigger for new layout
          if ((window as any).ScrollTrigger) {
            setTimeout(() => (window as any).ScrollTrigger.refresh(), 300);
          }
        },

        toggle() {
          this.apply(this.current === 'en' ? 'ar' : 'en');
        },

        init() {
          this.apply(this.current);
          // Wire both desktop and mobile toggles
          document.getElementById('lang-toggle')?.addEventListener('click', () => this.toggle());
          document.getElementById('lang-toggle-mobile')?.addEventListener('click', () => this.toggle());
        }
      };

      window.i18n = i18n;

      declare global {
        interface Window { i18n: typeof i18n; }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => i18n.init());
      } else {
        i18n.init();
      }
    </script>
  </body>
</html>
